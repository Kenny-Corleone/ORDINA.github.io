  "description": "Premium personal finance and life management suite - Your Life Order Assistant",
  "main": "index.html",
  "scripts": {
    "start": "python -m http.server 8000",
    "dev": "python -m http.server 8000",
    "serve": "npx http-server -p 8000 -c-1",
